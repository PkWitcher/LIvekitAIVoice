# ──────────────────────────────────────────────
# LiveKit Server
# ──────────────────────────────────────────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ──────────────────────────────────────────────
# Deepgram (STT + TTS)
# Get key at: https://console.deepgram.com
# ──────────────────────────────────────────────
DEEPGRAM_API_KEY=

# ──────────────────────────────────────────────
# Groq (Primary LLM — free tier)
# Get key at: https://console.groq.com
# ──────────────────────────────────────────────
GROQ_API_KEY=

# ──────────────────────────────────────────────
# OpenAI (Fallback LLM + optional TTS)
# ──────────────────────────────────────────────
OPENAI_API_KEY=

# ──────────────────────────────────────────────
# SIP Trunk — Vobiz / Exotel / Plivo
# ──────────────────────────────────────────────
VOBIZ_SIP_DOMAIN=sip.vobiz.com
VOBIZ_USERNAME=
VOBIZ_PASSWORD=
VOBIZ_OUTBOUND_NUMBER=
VOBIZ_SIP_TRUNK_ID=

# ──────────────────────────────────────────────
# Call Transfer Default
# ──────────────────────────────────────────────
DEFAULT_TRANSFER_NUMBER=+919876543210
